# Backend API URL (used by src/lib/api.ts)
VITE_API_URL=http://localhost:8000

# Base URL for auth/roadmapper APIs (used by src/lib/auth.ts and src/lib/roadmapper-api.ts)
# You can set this to http://localhost:8000 (auto-normalized to /api/v1)
VITE_API_BASE_URL=http://localhost:8000

# Optional Vite dev proxy target for /api requests
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

