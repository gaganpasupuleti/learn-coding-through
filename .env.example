# Copy to ".env" in this folder and adjust values. Vite reads this file only at dev-server startup.

# Google Sign-In (Web client ID from Google Cloud Console — must match backend GOOGLE_OAUTH_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# Backend API root. For local dev with `npm run dev`, leave BOTH lines empty so the browser calls
# same-origin `/api/v1/...` and Vite proxies to 8000 (see vite.config.ts). Only set these when you
# intentionally want the SPA to talk to another host (e.g. staging API).
# VITE_API_URL=http://127.0.0.1:8000
# VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_URL=
VITE_API_BASE_URL=

# Optional: proxy target for the Vite dev server only (vite.config.ts). The SPA does not read this;
# keep VITE_API_URL empty so the browser uses same-origin /api (proxied to this target).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# JobSpy job board API (separate backend). Local dev: leave empty — Vite proxies /jobs-api → 8001.
# Production (Railway CodeQuest frontend service): set to your public JobSpy API origin only, e.g.
# VITE_JOBS_API_URL=https://YOUR-JOBSPY-API-DOMAIN.up.railway.app
# Do NOT put DATABASE_URL, Postgres password, ADMIN_API_KEY, or AUTH_SECRET here — those belong on JobSpy only.
VITE_JOBS_API_URL=
VITE_JOBS_API_PROXY_TARGET=http://127.0.0.1:8001

# Optional local-only default for JobSpy Ops (enter key in admin UI in production; never ship admin keys in frontend env).
VITE_JOBS_ADMIN_API_KEY=
