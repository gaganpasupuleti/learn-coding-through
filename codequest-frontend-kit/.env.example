# Copy to .env

# Main Code Quest app (proxy target for /practice and /open)
VITE_LEGACY_APP_URL=http://127.0.0.1:5000

# Backend API — sandbox proxies /api and /health here
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_JOBS_API_PROXY_TARGET=http://127.0.0.1:8001

# Leave empty to use same-origin /api (recommended with proxy)
VITE_API_URL=
VITE_API_BASE_URL=
