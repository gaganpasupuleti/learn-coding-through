APP_NAME=Student Career Acceleration Portal
ENVIRONMENT=development
SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Supabase pooled connection string (recommended for app/runtime)
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Keep false once migrations are in place
AUTO_CREATE_TABLES=false

# Add frontend URLs here later
CORS_ORIGINS=http://localhost:5000,http://localhost:5173

# Production/staging guidance:
# ENVIRONMENT=production
# SECRET_KEY=<strong-random-value>
# AUTO_CREATE_TABLES=false
# CORS_ORIGINS=https://your-frontend-domain.com
