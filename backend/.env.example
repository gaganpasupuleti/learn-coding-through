APP_NAME=Student Career Acceleration Portal
ENVIRONMENT=development
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+psycopg2://<railway-user>:<railway-password>@<railway-host>:<railway-port>/<railway-db>
AUTO_CREATE_TABLES=false
# Include both localhost and 127.0.0.1 if you open the app either way in the browser.
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173
# First admin on a fresh DB: set email + password, restart API. Optional: PROMOTE_ADMIN_EMAILS=comma@example.com,other@example.com (promotes existing users only).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin

# Comma-separated admin emails with unlimited job-post quota (pro tier). Role SUPER_ADMIN also bypasses the free cap (MAX_FREE_TIER_JOBS).
ADMIN_PRO_JOB_TIER_EMAILS=

# Google Sign-In (Web application OAuth client ID). Must match VITE_GOOGLE_CLIENT_ID on the frontend.
# This backend verifies Google ID tokens only — no GOOGLE_CLIENT_SECRET is required for that flow.
GOOGLE_OAUTH_CLIENT_ID=

# Optional: auto-start Resume-Matcher backend when this backend starts.
# Resume-Matcher integration removed from this repository.

# Production/staging guidance:
# ENVIRONMENT=production
# SECRET_KEY=<strong-random-value>
# AUTO_CREATE_TABLES=false
# CORS_ORIGINS=https://your-frontend-domain.com
