APP_NAME=Student Career Acceleration Portal
ENVIRONMENT=development
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg2://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
AUTO_CREATE_TABLES=false
CORS_ORIGINS=http://localhost:5000,http://localhost:5173
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin

# Optional: auto-start Resume-Matcher backend when this backend starts.
AUTO_START_RESUME_BACKEND=false
RESUME_BACKEND_HOST=127.0.0.1
RESUME_BACKEND_PORT=8001
# Optional explicit Python executable for Resume-Matcher backend.
# If empty, backend tries: resume app/Resume-Matcher/apps/backend/.venv first, then current Python.
RESUME_BACKEND_PYTHON=

# Production/staging guidance:
# ENVIRONMENT=production
# SECRET_KEY=<strong-random-value>
# AUTO_CREATE_TABLES=false
# CORS_ORIGINS=https://your-frontend-domain.com
