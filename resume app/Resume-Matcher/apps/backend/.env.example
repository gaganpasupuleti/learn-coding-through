# Resume Matcher Backend – Environment Variables
# Copy this file to .env and fill in the values.

# --- Lean ATS Analyzer ---
# Set to "true" for local Ollama, "false" to use Hugging Face cloud
USE_LOCAL_AI=true
# Required when USE_LOCAL_AI=false. Get a read token from https://huggingface.co/settings/tokens
HF_API_KEY=your_hugging_face_read_token_here
